# Copy to .env and adjust. Consumed by the backend (see docs/02-architecture.md §Config).

# HTTP listen address
EAGORA_ADDR=:8080

# PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL=postgres://eagora:eagora@localhost:5432/eagora?sslmode=disable

# Seeding: auto (seed if empty) | off (never contact upstreams) | force (re-ingest)
EAGORA_SEED=auto

# R9 universal fallback language
EAGORA_FALLBACK_LANG=en

# HMAC secret for the stateless 24h access token (REQUIRED in prod)
EAGORA_TOKEN_SECRET=dev-insecure-change-me
EAGORA_ACCESS_TTL=24h
EAGORA_ADDS_PER_TOKEN=1

# Per-session vote rate limit (R11)
EAGORA_RATELIMIT=on
EAGORA_VOTE_BURST=20
EAGORA_VOTE_RATE=1

# Humanity check (R12)
EAGORA_HUMAN_PROVIDER=dissent
EAGORA_HUMAN_TTL=24h

# Production: serve the built SPA same-origin from this dir (prod image sets /web).
# Leave empty in dev — Vite serves the SPA and proxies /api.
# EAGORA_STATIC_DIR=/web

# Dev-only: CORS origin when the SPA is served cross-origin
# EAGORA_CORS_ORIGIN=http://localhost:5173
